# ─────────────────────────────────────────────────────────────────────────────
# poe1-trainer — przykładowy plik konfiguracyjny
#
# Skopiuj ten plik do .env i dopasuj wartości do swojego środowiska.
# Plik .env nigdy nie powinien być commitowany do repozytorium.
# ─────────────────────────────────────────────────────────────────────────────

# ── Baza danych ──────────────────────────────────────────────────────────────
# DSN połączenia z PostgreSQL.
# W trybie Docker Compose (dev) wartość jest nadpisywana bezpośrednio w pliku
# docker-compose.dev.yml — tu przydaje się przy uruchomieniu poza Dockerem.
DATABASE_URL=postgres://poe:poe@localhost:5432/poetrainer?sslmode=disable

# ── Backend ──────────────────────────────────────────────────────────────────
# Port, na którym nasłuchuje serwer HTTP.
PORT=8080

# ── Integracja z logiem gry (opcjonalne) ─────────────────────────────────────
# Katalog na hoście zawierający Client.txt (montowany do kontenera jako /mnt/poe-logs).
# Windows/Steam:
POE_LOG_DIR=C:/Program Files (x86)/Steam/steamapps/common/Path of Exile/logs

# Ścieżka do Client.txt widziana wewnątrz kontenera Docker.
# Gdy korzystasz z docker-compose.dev.yml zostaw wartość jak poniżej.
# Poza Dockerem możesz wpisać bezpośrednią ścieżkę hosta.
LOG_PATH=/mnt/poe-logs/Client.txt

# ── GGG OAuth (faza 2, opcjonalne) ───────────────────────────────────────────
# Integracja z GGG API nie jest wymagana do działania aplikacji.
# Wypełnij tylko jeśli testujesz autoryzację OAuth.
# GGG_CLIENT_ID=
# GGG_CLIENT_SECRET=
# GGG_REDIRECT_URI=http://localhost:8080/auth/callback
